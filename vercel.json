{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/scheduled-report", "schedule": "30 6 * * *"  },
    { "path": "/api/scheduled-report", "schedule": "30 12 * * *" },
    { "path": "/api/scheduled-report", "schedule": "30 18 * * *" }
  ]
}
