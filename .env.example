# Supabase PostgreSQL connection string (required — set in Vercel environment variables)
# Use the "Transaction" mode pooler URL (port 6543) for Vercel serverless:
#   Supabase dashboard → Project → Connect → Transaction mode
VIN_TRACKER_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: override API base URL (leave unset — frontend and backend are co-deployed on Vercel)
# VITE_API_URL=
